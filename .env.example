# Variables de entorno de VideoForge.
# Copia este archivo a ".env" (NO subir .env real al repo) y completa los valores.

# ── App / servidor ──────────────────────────────────────────────
DEBUG=false
PUBLIC_BASE_URL=http://localhost:8080
# APP_SECRET_KEY firma las cookies de sesion -- usa un valor largo y aleatorio propio,
# nunca reutilices el de otro entorno.
APP_SECRET_KEY=

# ── Base de datos (MySQL) ────────────────────────────────────────
DB_HOST=
DB_HOST_FALLBACK=
DB_USER=
DB_PASSWORD=
DB_NAME=
DB_PORT=3306

# ── Stripe (pagos) ───────────────────────────────────────────────
STRIPE_SECRET_KEY=

# ── OpenAI (Vision para analyze_image, Whisper API) ─────────────
OPENAI_API_KEY_INLINE=
OPENAI_WHISPER_KEY=
# Opcionales, afinan el analisis de imagen en scene_prompt_service/openai_vision_client:
# OPENAI_IMAGE_MODEL=gpt-4o-mini
# OPENAI_IMAGE_DETAIL=auto
# OPENAI_IMAGE_MAX_TOKENS=1200
# OPENAI_IMAGE_TEMPERATURE=0.4

# ── OpenRouter (generacion de prompts por escena) ───────────────
OPENROUTER_API_KEY=
# Opcionales, afinan scene_prompt_service.py:
# OPENROUTER_MODEL=
# OPENROUTER_TEMPERATURE=
# OPENROUTER_SCENE_BATCH=
# OPENROUTER_PARALLEL_BATCHES=
# OPENROUTER_MAX_TOKENS_PER_SCENE=
# OPENROUTER_MISSING_RETRY_CAP=
# OPENROUTER_WHISK_SANITIZE_MODEL=openai/gpt-4o-mini

# ── Replicate (WhisperX remoto, backend "whisperx" de Render) ──
REPLICATE_API_KEY=
# REPLICATE_WHISPERX_MODEL=victor-upmeet/whisperx   # documentado pero no usado hoy (version pineada en codigo)

# ── Render local (FFmpeg + Modal) -- todas opcionales, tienen default ──
# VF_FFMPEG_THREADS=0            # 0 = todos los nucleos
# VF_FFMPEG_X264_THREADS=0
# VF_FFMPEG_VIDEO_ENCODER=auto   # auto|libx264|h264_nvenc|h264_qsv|h264_amf
# VF_MODAL_BATCH_SIZE=28         # 8-40
# VF_RENDER_SEG_PARALLEL=2       # 1-6
# VF_RENDER_VID_CLIP_PARALLEL=2  # 1-4
# VF_MODAL_READ_TIMEOUT_SEC=240
# VF_MODAL_CONNECT_TIMEOUT_SEC=35
# VF_MODAL_MAX_RETRIES=4

# ── Guion (segmentacion de escenas) -- opcionales ───────────────
# GUION_MIN_WORDS_PER_SCENE=
# GUION_TINY_TAIL_WORDS=

# ── Reservadas para secciones aun no migradas ───────────────────
# GOOGLE_FLOW_API_KEY: usada por el generador de imagenes de Google Flow (activo hoy en
# old/launcher.py). La seccion Flow todavia no se porto a src/ (queda para el final junto
# con Gentube/Idea2Video), pero la variable ya existe y se necesitara ahi.
GOOGLE_FLOW_API_KEY=
# Usadas por Gentube (busqueda de imagenes de stock), tampoco migrado aun:
# SERPER_API_KEY=
# PEXELS_API_KEY=
# PIXABAY_API_KEY=
# UNSPLASH_ACCESS_KEY=
